{
  "name": "@semanticlayer/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool for SemanticLayer — extract AI-optimized content from any URL",
  "author": "Bahri Kement",
  "license": "MIT",
  "bin": {
    "semanticlayer": "./bin/semanticlayer.js",
    "sl": "./bin/semanticlayer.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@semanticlayer/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.6.0"
  }
}
