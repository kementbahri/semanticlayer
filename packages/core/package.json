{
  "name": "@semanticlayer/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core extraction engine for SemanticLayer",
  "author": "Bahri Kement",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "linkedom": "^0.18.0",
    "playwright": "^1.48.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
