{
  "name": "@semanticlayer/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for SemanticLayer — use from Cursor, VS Code, or any MCP-compatible AI tool",
  "author": "Bahri Kement",
  "license": "MIT",
  "bin": {
    "semanticlayer-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@semanticlayer/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.6.0"
  }
}
